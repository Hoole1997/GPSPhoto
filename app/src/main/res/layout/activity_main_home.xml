<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 全屏地图 -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mapContainer"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 扫描动效覆盖层（点击地图后在点击处显示） -->
    <com.example.lcb.app.streetview.ScanOverlayView
        android:id="@+id/scanOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 顶部搜索框 -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="top"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_search_bar"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/search_hint"
            android:src="@drawable/ic_search" />

        <TextView
            android:id="@+id/searchHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/search_hint"
            android:textColor="#9AA3AE"
            android:textSize="15sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:layout_marginEnd="12dp"
            android:background="#E2E6EA" />

        <ImageView
            android:id="@+id/settingsButton"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/action_settings"
            android:src="@drawable/ic_settings" />

    </LinearLayout>

    <!-- 地图控制按钮组（自定义圆形卡片样式） -->
    <LinearLayout
        android:id="@+id/mapControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_anchor="@id/bottomSheet"
        app:layout_anchorGravity="top|end">

        <!-- 竖向缩放滑块（与圆按钮同宽，紧凑） -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_zoom_slider"
            android:elevation="6dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@string/action_zoom_in"
                android:src="@drawable/ic_zoom_in" />

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="104dp"
                android:layout_marginVertical="6dp"
                android:clipChildren="false">

                <SeekBar
                    android:id="@+id/zoomSeekBar"
                    android:layout_width="104dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:max="100"
                    android:maxHeight="3dp"
                    android:minHeight="3dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progress="74"
                    android:progressDrawable="@drawable/zoom_seekbar_progress"
                    android:rotation="270"
                    android:splitTrack="false"
                    android:thumb="@drawable/zoom_seekbar_thumb"
                    android:thumbOffset="0dp" />

            </FrameLayout>

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@string/action_zoom_out"
                android:src="@drawable/ic_zoom_out" />

        </LinearLayout>

        <ImageView
            android:id="@+id/mapTypeFab"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_map_control"
            android:clickable="true"
            android:contentDescription="@string/action_map_type"
            android:elevation="6dp"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_map_satellite" />

        <ImageView
            android:id="@+id/myLocationFab"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_map_control"
            android:clickable="true"
            android:contentDescription="@string/action_my_location"
            android:elevation="6dp"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_my_location" />

    </LinearLayout>

    <!-- 底部可上拉面板 -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        app:behavior_hideable="false"
        app:behavior_peekHeight="80dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- 拖拽指示条 -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_sheet_handle" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabBackground="@android:color/transparent"
            app:tabGravity="fill"
            app:tabIndicatorColor="#2E7CF6"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed"
            app:tabSelectedTextColor="#2E7CF6"
            app:tabTextColor="#8A94A0" />

        <!-- 底部面板内的原生广告位 -->
        <FrameLayout
            android:id="@+id/sheetAdContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/streetViewRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1116">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 加载覆盖层 -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0E1116"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/loadingSpinner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#4A9CFF" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/sv_loading"
            android:textColor="#C7D0DA"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/loadingProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4A9CFF"
            android:progressBackgroundTint="#2A2F37" />

    </LinearLayout>

    <!-- 错误层 -->
    <LinearLayout
        android:id="@+id/errorOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0E1116"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sv_error"
            android:textColor="#C7D0DA"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_sv_retry"
            android:paddingHorizontal="26dp"
            android:paddingVertical="11dp"
            android:text="@string/sv_retry"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 返回按钮 -->
    <ImageView
        android:id="@+id/backButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_margin="14dp"
        android:background="@drawable/bg_sv_back"
        android:contentDescription="@string/sv_back"
        android:padding="9dp"
        android:src="@drawable/ic_arrow_back"
        tools:ignore="RtlHardcoded" />

    <!-- 标题条 -->
    <TextView
        android:id="@+id/titleBar"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_margin="14dp"
        android:background="@drawable/bg_sv_title"
        android:gravity="center"
        android:maxWidth="220dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingHorizontal="18dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="埃菲尔铁塔"
        tools:visibility="visible" />

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_permission_dialog"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="24dp"
    android:paddingBottom="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/perm_dialog_title"
        android:textColor="#1A1F2B"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="@string/perm_dialog_message"
        android:textColor="#6B7280"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/grantButton"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_permission_button"
        android:gravity="center"
        android:text="@string/perm_dialog_grant"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
